// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id          String   @id @default(uuid())
  name        String
  address     String?

  shopCode    String   @unique 

  email       String?
  phone       String?

  city        String?
  state       String?
  country     String?
  pincode     String?

  gstNumber   String?
  currency    String   @default("INR")

  logoUrl     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  users       User[]
  products    Product[]
  orders      Order[]
}

model User {
  id          String   @id @default(uuid())

  name        String?
  email       String   @unique
  password    String

  avatarUrl   String?  

  role        UserRole  @default(STAFF)
  isActive    Boolean   @default(true)

  shopCode    String
  shop        Shop      @relation(fields: [shopCode], references: [shopCode])

  ordersCreated Order[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  STAFF
}

enum OrderStatus {
  PAID
  PENDING
  CANCELLED
}

model OrderItem {
  id         String   @id @default(uuid())

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])

  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  quantity   Int
  price      Float   
}

// ================== ORDER ==================
model Order {
  id           String   @id @default(uuid())

  shopCode     String
  shop         Shop     @relation(fields: [shopCode], references: [shopCode])

  totalAmount  Float
  discount     Float?   @default(0)
  tax          Float?   @default(0)

  status       OrderStatus @default(PAID)

  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])

  createdAt    DateTime @default(now())

  items        OrderItem[]
}

// ================== PRODUCT ==================
model Product {
  id            String   @id @default(uuid())

  name          String
  description   String?

  price         Float
  costPrice     Float?

  barcode       String   @unique  
  sku           String?

  quantity      Int      @default(0)
  minStock      Int?

  unit          String?  

  category      String? 

  imageUrl      String?

  isActive      Boolean  @default(true)

  shopCode      String
  shop          Shop     @relation(fields: [shopCode], references: [shopCode])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  orderItems    OrderItem[]
}