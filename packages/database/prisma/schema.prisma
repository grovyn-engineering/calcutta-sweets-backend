// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id      String  @id @default(uuid())
  name    String
  address String?

  shopCode String @unique

  email String?
  phone String?

  city    String?
  state   String?
  country String?
  pincode String?

  gstNumber String?
  currency  String  @default("INR")

  logoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  users        User[]
  products     Product[]
  orders       Order[]
  roleRequests RoleRequest[]
}

model User {
  id String @id @default(uuid())

  name     String?
  email    String  @unique
  password String

  avatarUrl String?
  phone     String?

  role     UserRole @default(STAFF)
  isActive Boolean  @default(true)

  shopCode String
  shop     Shop   @relation(fields: [shopCode], references: [shopCode])

  ordersCreated Order[]
  roleRequests  RoleRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  STAFF
  SUPER_ADMIN
}

enum OrderStatus {
  PAID
  PENDING
  CANCELLED
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  quantity Int
  price    Float
}

// ================== ORDER ==================
model Order {
  id String @id @default(uuid())

  shopCode String
  shop     Shop   @relation(fields: [shopCode], references: [shopCode])

  totalAmount Float
  discount    Float? @default(0)
  tax         Float? @default(0)

  status OrderStatus @default(PAID)

  /**
   * POS settlement: CASH | UPI_CARD
   */
  paymentMethod String @default("CASH")

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  customerName  String?
  customerPhone String?
  customerEmail String?

  createdAt DateTime    @default(now())
  items     OrderItem[]
}

enum Unit {
  KG
  GM
  LTR
  ML
  PC
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  products Product[]

  createdAt DateTime @default(now())
}

model Product {
  id String @id @default(uuid())

  name        String
  description String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  shopCode String
  shop     Shop   @relation(fields: [shopCode], references: [shopCode])

  isActive Boolean @default(true)

  variants   ProductVariant[]
  orderItems OrderItem[]
  images     ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  name String // e.g. "200g", "1kg", "Regular"

  price     Float
  costPrice Float?

  barcode String  @unique
  sku     String?

  hsnCode String?

  quantity Int  @default(0)
  minStock Int?

  unit Unit?

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id  String @id @default(uuid())
  url String

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

model RoleRequest {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  shopCode      String
  shop          Shop          @relation(fields: [shopCode], references: [shopCode])
  requestedRole UserRole
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
