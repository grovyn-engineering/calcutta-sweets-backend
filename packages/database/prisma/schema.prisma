// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id      String  @id @default(uuid())
  name    String
  address String?
  logoUrl String?

  shopCode String @unique

  email String?
  phone String?

  city    String?
  state   String?
  country String?
  pincode String?

  gstNumber String?
  currency  String  @default("INR")

  upiId String? // UPI ID for payments (e.g. shop@upi)

  isFactory Boolean @default(false)

  allowNextDayBooking       Boolean @default(false)
  allowBookingWhenOutOfStock Boolean @default(false)

  cgstRate Float @default(2.5)
  sgstRate Float @default(2.5)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  users        User[]
  products     Product[]
  orders       Order[]
  roleRequests RoleRequest[]
  transfersOut StockTransferRequest[] @relation("TransfersOut")
  transfersIn  StockTransferRequest[] @relation("TransfersIn")
}

model User {
  id String @id @default(uuid())

  name     String?
  email    String  @unique
  password String

  avatarUrl String?
  phone     String?

  role     UserRole @default(STAFF)
  isActive Boolean  @default(true)

  /// Optional per-user permission toggles; merged with defaults for `role` (see SettingsService).
  permissionOverrides Json?

  shopCode String
  shop     Shop   @relation(fields: [shopCode], references: [shopCode])

  ordersCreated Order[]
  roleRequests  RoleRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  STAFF
  SUPER_ADMIN
}

enum OrderStatus {
  PAID
  PENDING
  CANCELLED
  DRAFT
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  quantity Int
  price    Float
}

// ================== ORDER ==================
model Order {
  id String @id @default(uuid())

  shopCode String
  shop     Shop   @relation(fields: [shopCode], references: [shopCode])

  totalAmount Float
  discount    Float? @default(0)
  tax         Float? @default(0)

  status OrderStatus @default(PAID)

  /**
   * POS settlement: CASH | UPI_CARD
   */
  paymentMethod String @default("CASH")

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  customerName  String?
  customerPhone String?
  customerEmail String?

  orderSource OrderSource @default(POS)
  pickupTime  DateTime?

  createdAt DateTime    @default(now())
  items     OrderItem[]
}

enum OrderSource {
  POS
  WEBSITE
}

enum Unit {
  KG
  GM
  LTR
  ML
  PC
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  products Product[]

  createdAt DateTime @default(now())
}

model Product {
  id String @id @default(uuid())

  name        String
  description String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  shopCode String
  shop     Shop   @relation(fields: [shopCode], references: [shopCode])

  isActive          Boolean @default(true)
  isListedOnWebsite Boolean @default(false)

  variants   ProductVariant[]
  orderItems OrderItem[]
  images     ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopCode])
  @@index([categoryId])
}

model ProductVariant {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  name String // e.g. "200g", "1kg", "Regular"

  price     Float
  costPrice Float?

  barcode String @unique
  sku     String?

  hsnCode String?

  quantity Int  @default(0)
  minStock Int?

  unit Unit?

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductImage {
  id  String @id @default(uuid())
  url String

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

model RoleRequest {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  shopCode      String
  shop          Shop          @relation(fields: [shopCode], references: [shopCode])
  requestedRole UserRole
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ================== STOCK TRANSFERS ==================

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

model StockTransferRequest {
  id           String         @id @default(uuid())
  fromShopCode String
  fromShop     Shop           @relation("TransfersOut", fields: [fromShopCode], references: [shopCode])
  toShopCode   String
  toShop       Shop           @relation("TransfersIn", fields: [toShopCode], references: [shopCode])
  status       TransferStatus @default(PENDING)
  note         String?
  createdById  String?
  approvedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        StockTransferItem[]
}

model StockTransferItem {
  id          String               @id @default(uuid())
  requestId   String
  request     StockTransferRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  barcode     String
  productName String
  variantName String
  quantity    Int
}
